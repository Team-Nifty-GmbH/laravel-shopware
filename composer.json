{
    "name": "team-nifty-gmbh/laravel-shopware",
    "description": "Laravel integration for the Shopware 6 Admin API SDK",
    "type": "library",
    "license": "MIT",
    "homepage": "https://team-nifty.com",
    "autoload": {
        "psr-4": {
            "TeamNiftyGmbH\\LaravelShopware\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "TeamNiftyGmbH\\LaravelShopware\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Patrick Weh",
            "email": "pw@team-nifty.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "illuminate/support": "^12.0|^13.0",
        "team-nifty-gmbh/shopware-sdk": "dev-main"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.1"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "lint": "vendor/bin/pint --test",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TeamNiftyGmbH\\LaravelShopware\\ShopwareServiceProvider"
            ],
            "aliases": {
                "Shopware": "TeamNiftyGmbH\\LaravelShopware\\Facades\\Shopware"
            }
        }
    }
}
